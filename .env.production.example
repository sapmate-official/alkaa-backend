# Production Environment Variables Required

# Database (Update to production database)
DATABASE_URL=postgresql://your-prod-db-url

# Firebase FCM Configuration (CRITICAL for notifications)
GOOGLE_APPLICATION_CREDENTIALS_JSON=base64_encoded_service_account_json
# OR
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Email Service
RESEND_API_KEY=your_production_resend_key
SENDER_EMAIL=noreply@yourdomain.com

# Frontend Domain (Update to production URL)
FRONTEND_DOMAIN=https://your-production-domain.com
CLIENT_URL=https://your-production-domain.com

# JWT Secrets (Generate new secure secrets for production)
REFRESH_TOKEN_SECRET=your_super_secure_refresh_secret_minimum_32_characters
ACCESS_TOKEN_SECRET=your_super_secure_access_secret_minimum_32_characters

# VAPID Keys for Web Push (Optional, if using web push)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Environment
NODE_ENV=production

# Super Admin Secret (Change for production)
SUPER_ADMIN_SECRET_KEY=your_production_super_admin_secret

# Twilio (if using SMS)
TWILLO_ACCOUNT_SID=your_production_twilio_sid
TWILLO_AUTH_TOKEN=your_production_twilio_token
TWILLO_VERIFY_SID=your_production_verify_sid

# Brevo API (if using)
BREVO_API_KEY=your_production_brevo_key

# Cashfree (Update to production keys)
CASHFREE_APP_ID=your_production_cashfree_app_id
CASHFREE_SECRET_KEY=your_production_cashfree_secret
CASHFREE_ENVIRONMENT=production

# Port
PORT=3000
