{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/api/v2/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/api/v3/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/public/(.*)",
      "dest": "public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "buildCommand": "prisma generate",
  "installCommand": "npm install",
  "outputDirectory": ".",
