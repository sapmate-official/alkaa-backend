model TrackingSession {
  id                   String               @id @default(cuid())
  userId               String
  orgId                String
  attendanceId         String
  workMode             WorkMode             @default(OFFICE)
  startLocation        Json
  currentLocation      Json?
  endLocation          Json?
  startTime            DateTime             @default(now())
  endTime              DateTime?
  lastLocationUpdate   DateTime?
  isActive             Boolean              @default(true)
  endReason            String?
  endedBy              String?
  updatedBy            String?
  outstationData       Json?
  settings             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  attendance           AttendanceRecord     @relation(fields: [attendanceId], references: [id])
  organization         Organization         @relation(fields: [orgId], references: [id])
  user                 User                 @relation(fields: [userId], references: [id])
  violations           GeofenceViolation[]
  locationUpdates      LocationUpdate[]

  @@index([userId, isActive])
  @@index([orgId, startTime])
}

model LocationUpdate {
  id                String          @id @default(cuid())
  sessionId         String
  latitude          Float
  longitude         Float
  accuracy          Float?
  address           String?
  timestamp         DateTime        @default(now())
  isCompliant       Boolean         @default(true)
  validationNotes   String?
  isBreakActive     Boolean         @default(false)
  breakId           String?
  validationSkipped Boolean         @default(false)
  session           TrackingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}

enum WorkMode {
  OFFICE
  OUTSTATION
  REMOTE
  CLIENT_SITE
}
